                <!-- 5. TESTS TAB -->
                <div id="tab-tests" class="tab-content hidden grid grid-cols-1 lg:grid-cols-12 gap-6">
                    <!-- Create Test Form -->
                    <div class="lg:col-span-4 bg-white/95 backdrop-blur-md p-6 rounded-3xl border border-slate-200 shadow-xl h-fit">
                        <h3 class="font-black text-slate-900 mb-4 text-lg">નવો ટેસ્ટ</h3>
                        <form id="test-form" onsubmit="createTest(event)" class="space-y-4">
                            <div>
                                <label class="block text-xs font-bold text-slate-500 mb-1.5 uppercase tracking-wider">ટેસ્ટનું નામ</label>
                                <input type="text" id="test-name" required placeholder="દા.ત. યુનિટ ટેસ્ટ-૧" class="w-full px-4 py-2.5 border border-slate-200 rounded-2xl text-sm outline-none focus:ring-2 focus:ring-violet-400 transition">
                            </div>
                            <div class="grid grid-cols-2 gap-4">
