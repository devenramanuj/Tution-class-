<!DOCTYPE html>
<html lang="gu">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>અક્ષર ટ્યુટોરીયલ્સ મેનેજર</title>
    <!-- Tailwind CSS (ડિઝાઇન માટે) -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        try {
            tailwind.config = {
                theme: {
                    extend: {
                        colors: {
                            brand: {
                                50: '#f5f3ff',
                                100: '#ede9fe',
                                500: '#8b5cf6',
                                600: '#7c3aed',
                                700: '#6d28d9',
                                900: '#4c1d95'
                            }
                        }
                    }
                }
            }
        } catch (e) {
            console.error("Tailwind loading skipped.");
        }
    </script>
</head>
<body class="bg-gradient-to-tr from-slate-100 via-violet-50 to-blue-50 font-sans text-slate-800 antialiased min-h-screen">

    <div class="flex h-screen overflow-hidden">
        
        <!-- SIDEBAR (કોમ્પ્યુટર અને ટેબલેટ માટે) -->
        <aside class="w-64 bg-slate-900 text-slate-200 flex flex-col justify-between hidden md:flex border-r border-slate-800 shadow-2xl">
            <div class="p-6">
                <div class="flex items-center gap-3 mb-8">
                    <div class="p-2.5 bg-gradient-to-br from-violet-500 to-fuchsia-600 rounded-2xl text-white shadow-lg shadow-violet-500/30">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M21.42 10.922a1 1 0 0 0-.019-1.838L12.83 5.18a2 2 0 0 0-1.66 0L2.6 9.08a1 1 0 0 0 0 1.832l8.57 3.908a2 2 0 0 0 1.66 0z"/><path d="M6 12v5c0 2 2 3 6 3s6-1 6-3v-5M21.5 12H18"/></svg>
                    </div>
                    <div>
                        <h1 class="text-base font-extrabold text-white tracking-wide bg-gradient-to-r from-violet-200 to-fuchsia-300 bg-clip-text text-transparent">અક્ષર ટ્યુટોરીયલ્સ</h1>
                        <span class="text-[10px] text-emerald-400 font-extrabold uppercase tracking-widest">મેનેજમેન્ટ સિસ્ટમ</span>
                    </div>
                </div>
                
                <nav class="space-y-2">
                    <button onclick="switchTab('dashboard')" id="btn-dashboard" class="tab-btn w-full flex items-center gap-3 px-4 py-3 rounded-xl bg-gradient-to-r from-violet-600 to-fuchsia-600 text-white font-semibold transition shadow-lg shadow-violet-600/30">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="12" rx="1"/><rect width="7" height="5" x="3" y="16" rx="1"/></svg>
                        ડેશબોર્ડ
                    </button>
                    <button onclick="switchTab('students')" id="btn-students" class="tab-btn w-full flex items-center gap-3 px-4 py-3 rounded-xl text-slate-400 hover:bg-slate-800 hover:text-white font-semibold transition">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
                        વિદ્યાર્થીઓ
                    </button>
                    <button onclick="switchTab('attendance')" id="btn-attendance" class="tab-btn w-full flex items-center gap-3 px-4 py-3 rounded-xl text-slate-400 hover:bg-slate-800 hover:text-white font-semibold transition">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><rect width="18" height="18" x="3" y="4" rx="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/><path d="m9 16 2 2 4-4"/></svg>
                        હાજરી પત્રક
                    </button>
                    <button onclick="switchTab('fees')" id="btn-fees" class="tab-btn w-full flex items-center gap-3 px-4 py-3 rounded-xl text-slate-400 hover:bg-slate-800 hover:text-white font-semibold transition">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/></svg>
                        ફી કલેક્શન
                    </button>
                    <button onclick="switchTab('tests')" id="btn-tests" class="tab-btn w-full flex items-center gap-3 px-4 py-3 rounded-xl text-slate-400 hover:bg-slate-800 hover:text-white font-semibold transition">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
                        પરીક્ષાઓ
                    </button>
                </nav>
            </div>
            <div class="p-6 border-t border-slate-800 flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-gradient-to-r from-violet-500 to-fuchsia-500 flex items-center justify-center text-xs font-bold text-white shadow">AD</div>
                <div>
                    <p class="text-xs font-bold text-white">એડમિન મોડ</p>
                    <p class="text-[10px] text-violet-400 font-medium">મોબાઈલ રિસ્પોન્સિવ</p>
                </div>
            </div>
        </aside>

        <!-- MAIN WINDOW -->
        <div class="flex-1 flex flex-col overflow-y-auto">
            
            <!-- TOP BAR -->
            <header class="bg-white/80 backdrop-blur-md border-b border-slate-200 px-6 py-4 flex justify-between items-center sticky top-0 z-10 shadow-sm">
                <div>
                    <h2 id="page-title" class="text-2xl font-black text-slate-900 bg-gradient-to-r from-slate-900 to-violet-800 bg-clip-text text-transparent">ડેશબોર્ડ</h2>
                    <p id="page-subtitle" class="text-xs font-medium text-slate-500 mt-0.5">ક્લાસની આજની સ્થિતિ</p>
                </div>
                <div class="flex items-center gap-4">
                    <div class="flex items-center gap-2 text-xs bg-gradient-to-r from-violet-500 to-fuchsia-500 text-white font-bold px-3 py-1.5 rounded-xl shadow-md shadow-violet-500/10">
                        <span id="current-date">આજની તારીખ</span>
                    </div>
                </div>
            </header>

            <!-- MAIN CONTAINER -->
            <main class="p-4 md:p-6 pb-28 max-w-[1400px] w-full mx-auto flex-1">
                
                <!-- 1. DASHBOARD TAB -->
                <div id="tab-dashboard" class="tab-content space-y-6">
                    <!-- Colorful Gradients Stats Grid -->
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6">
                        <!-- Card 1: Students (Indigo Gradient) -->
                        <div class="bg-gradient-to-br from-indigo-500 via-indigo-600 to-violet-700 p-6 rounded-3xl text-white shadow-xl shadow-indigo-500/20 flex justify-between items-center relative overflow-hidden group">
                            <div class="absolute -right-6 -bottom-6 opacity-10 text-white transition-transform duration-500 group-hover:scale-110">
                                <svg class="w-24 h-24" fill="currentColor" viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
                            </div>
                            <div class="z-10">
                                <span class="text-xs text-indigo-100 font-extrabold uppercase tracking-widest">કુલ વિદ્યાર્થીઓ</span>
                                <h3 class="text-4xl font-black mt-2 tracking-tight" id="dash-total-students">0</h3>
                            </div>
                            <div class="p-3 bg-white/20 backdrop-blur-md rounded-2xl border border-white/10 text-white z-10 shadow-inner">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
                            </div>
                        </div>
                        <!-- Card 2: Attendance (Emerald Gradient) -->
                        <div class="bg-gradient-to-br from-emerald-400 via-emerald-500 to-teal-600 p-6 rounded-3xl text-white shadow-xl shadow-emerald-500/20 flex justify-between items-center relative overflow-hidden group">
                            <div class="absolute -right-6 -bottom-6 opacity-10 text-white transition-transform duration-500 group-hover:scale-110">
                                <svg class="w-24 h-24" fill="currentColor" viewBox="0 0 24 24"><rect width="18" height="18" x="3" y="4" rx="2"/><path d="m9 16 2 2 4-4"/></svg>
                            </div>
                            <div class="z-10">
                                <span class="text-xs text-emerald-100 font-extrabold uppercase tracking-widest">આજની હાજરી</span>
                                <h3 class="text-4xl font-black mt-2 tracking-tight" id="dash-attendance-rate">0%</h3>
                            </div>
                            <div class="p-3 bg-white/20 backdrop-blur-md rounded-2xl border border-white/10 text-white z-10 shadow-inner">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><rect width="18" height="18" x="3" y="4" rx="2"/><path d="m9 16 2 2 4-4"/></svg>
                            </div>
                        </div>
                        <!-- Card 3: Collected Fees (Cyan to Blue) -->
                        <div class="bg-gradient-to-br from-cyan-400 via-blue-500 to-indigo-600 p-6 rounded-3xl text-white shadow-xl shadow-blue-500/20 flex justify-between items-center relative overflow-hidden group">
                            <div class="absolute -right-6 -bottom-6 opacity-10 text-white transition-transform duration-500 group-hover:scale-110">
                                <svg class="w-24 h-24" fill="currentColor" viewBox="0 0 24 24"><rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/></svg>
                            </div>
                            <div class="z-10">
                                <span class="text-xs text-blue-100 font-extrabold uppercase tracking-widest">જમા થયેલ ફી</span>
                                <h3 class="text-4xl font-black mt-2 tracking-tight" id="dash-collected-fees">₹0</h3>
                            </div>
                            <div class="p-3 bg-white/20 backdrop-blur-md rounded-2xl border border-white/10 text-white z-10 shadow-inner">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/></svg>
                            </div>
                        </div>
                        <!-- Card 4: Pending Fees (Amber to Rose) -->
                        <div class="bg-gradient-to-br from-amber-400 via-orange-500 to-rose-600 p-6 rounded-3xl text-white shadow-xl shadow-orange-500/20 flex justify-between items-center relative overflow-hidden group">
                            <div class="absolute -right-6 -bottom-6 opacity-10 text-white transition-transform duration-500 group-hover:scale-110">
                                <svg class="w-24 h-24" fill="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/></svg>
                            </div>
                            <div class="z-10">
                                <span class="text-xs text-amber-100 font-extrabold uppercase tracking-widest">બાકી ફી</span>
                                <h3 class="text-4xl font-black mt-2 tracking-tight" id="dash-pending-fees">₹0</h3>
                            </div>
                            <div class="p-3 bg-white/20 backdrop-blur-md rounded-2xl border border-white/10 text-white z-10 shadow-inner">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/></svg>
                            </div>
                        </div>
                    </div>

                    <!-- Quick View Tables -->
                    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                        <!-- Recent Admissions Table -->
                        <div class="bg-white/95 backdrop-blur-md rounded-3xl border border-slate-200/80 p-6 shadow-xl shadow-slate-100/40">
                            <h4 class="font-black text-slate-950 mb-4 flex items-center gap-2 text-base">
                                <span class="w-2.5 h-2.5 rounded-full bg-violet-600"></span>
                                તાજેતરના એડમિશન
                            </h4>
                            <div class="overflow-x-auto">
                                <table class="w-full text-left">
                                    <thead>
                                        <tr class="border-b border-slate-100 text-xs text-slate-400 font-bold uppercase tracking-wider">
                                            <th class="pb-3">વિદ્યાર્થી નામ</th>
                                            <th class="pb-3 text-right">ધોરણ</th>
                                        </tr>
                                    </thead>
                                    <tbody id="dash-recent-students" class="divide-y divide-slate-100 text-sm"></tbody>
                                </table>
                            </div>
                        </div>

                        <!-- Pending Fees Table -->
                        <div class="bg-white/95 backdrop-blur-md rounded-3xl border border-slate-200/80 p-6 shadow-xl shadow-slate-100/40">
                            <h4 class="font-black text-rose-600 mb-4 flex items-center gap-2 text-base">
                                <span class="w-2.5 h-2.5 rounded-full bg-rose-600"></span>
                                બાકી ફી લિસ્ટ
                            </h4>
                            <div class="overflow-x-auto">
                                <table class="w-full text-left">
                                    <thead>
                                        <tr class="border-b border-slate-100 text-xs text-slate-400 font-bold uppercase tracking-wider">
                                            <th class="pb-3">વિદ્યાર્થી નામ</th>
                                            <th class="pb-3 text-right">બાકી ફી</th>
                                        </tr>
                                    </thead>
                                    <tbody id="dash-pending-list" class="divide-y divide-slate-100 text-sm"></tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 2. STUDENTS TAB -->
                <div id="tab-students" class="tab-content hidden grid grid-cols-1 lg:grid-cols-12 gap-6">
                    <!-- Left: Register Form -->
                    <div class="lg:col-span-4 bg-white/95 backdrop-blur-md p-6 rounded-3xl border border-slate-200 shadow-xl shadow-slate-100/40 h-fit">
                        <h3 class="font-black text-slate-900 mb-4 text-lg">નવું એડમિશન</h3>
                        <form id="add-student-form" onsubmit="saveStudent(event)" class="space-y-4">
                            <div>
                                <label class="block text-xs font-bold text-slate-500 mb-1.5 uppercase tracking-wider">વિદ્યાર્થીનું આખું નામ</label>
                                <input type="text" id="stu-name" required placeholder="દા.ત. રાહુલ મહેતા" class="w-full px-4 py-2.5 border border-slate-200 rounded-2xl text-sm outline-none focus:ring-2 focus:ring-violet-400 focus:border-transparent transition">
                            </div>
                            <div class="grid grid-cols-2 gap-4">
                                <div>
                                    <label class="block text-xs font-bold text-slate-500 mb-1.5 uppercase tracking-wider">ધોરણ</label>
                                    <select id="stu-class" class="w-full px-4 py-2.5 border border-slate-200 rounded-2xl text-sm outline-none bg-white">
                                        <option value="ધોરણ 8">ધોરણ 8</option>
                                        <option value="ધોરણ 9">ધોરણ 9</option>
                                        <option value="ધોરણ 10">ધોરણ 10</option>
                                        <option value="ધોરણ 11">ધોરણ 11</option>
                                        <option value="ધોરણ 12">ધોરણ 12</option>
                                    </select>
                                </div>
                                <div>
                                    <label class="block text-xs font-bold text-slate-500 mb-1.5 uppercase tracking-wider">બેચ</label>
                                    <select id="stu-batch" class="w-full px-4 py-2.5 border border-slate-200 rounded-2xl text-sm outline-none bg-white">
                                        <option value="સવારે 08-10">સવારે 08-10</option>
                                        <option value="બપોરે 12-02">બપોરે 12-02</option>
                                        <option value="સાંજે 04-06">સાંજે 04-06</option>
                                    </select>
                                </div>
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-slate-500 mb-1.5 uppercase tracking-wider">વાલીનો મોબાઇલ નંબર</label>
                                <input type="tel" id="stu-phone" required pattern="[0-9]{10}" placeholder="૧૦ આંકડાનો મોબાઈલ" class="w-full px-4 py-2.5 border border-slate-200 rounded-2xl text-sm outline-none focus:ring-2 focus:ring-violet-400 focus:border-transparent transition">
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-slate-500 mb-1.5 uppercase tracking-wider">માસિક ફી (₹)</label>
                                <input type="number" id="stu-fees" required value="1000" class="w-full px-4 py-2.5 border border-slate-200 rounded-2xl text-sm outline-none focus:ring-2 focus:ring-violet-400 focus:border-transparent transition">
                            </div>
                            <button type="submit" class="w-full bg-gradient-to-r from-violet-600 to-fuchsia-600 hover:from-violet-700 hover:to-fuchsia-700 text-white font-extrabold py-3 rounded-2xl text-sm transition shadow-lg shadow-violet-500/20">
                                એડમિશન સેવ કરો
                            </button>
                        </form>
                    </div>

                    <!-- Right: Table List -->
                    <div class="lg:col-span-8 bg-white/95 backdrop-blur-md p-6 rounded-3xl border border-slate-200 shadow-xl shadow-slate-100/40">
                        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-6">
                            <h3 class="font-black text-slate-900 text-xl">વિદ્યાર્થીઓની યાદી</h3>
                            <div class="flex gap-2 w-full sm:w-auto">
                                <input type="text" id="search-student" oninput="renderStudents()" placeholder="સર્ચ..." class="px-4 py-2.5 border border-slate-200 rounded-2xl text-sm w-full sm:w-48 outline-none focus:ring-2 focus:ring-violet-400 transition">
                                <select id="filter-class" onchange="renderStudents()" class="px-3 py-2.5 border border-slate-200 rounded-2xl text-sm outline-none bg-white font-semibold text-slate-700">
                                    <option value="all">બધા ધોરણ</option>
                                    <option value="ધોરણ 8">ધોરણ 8</option>
                                    <option value="ધોરણ 9">ધોરણ 9</option>
                                    <option value="ધોરણ 10">ધોરણ 10</option>
                                    <option value="ધોરણ 11">ધોરણ 11</option>
                                    <option value="ધોરણ 12">ધોરણ 12</option>
                                </select>
                            </div>
                        </div>

                        <div class="overflow-x-auto">
                            <table class="w-full text-left">
                                <thead>
                                    <tr class="border-b border-slate-100 text-xs text-slate-400 font-bold uppercase tracking-wider">
                                        <th class="pb-3 px-2">નામ</th>
                                        <th class="pb-3 px-2">ધોરણ</th>
                                        <th class="pb-3 px-2 text-center">ક્રિયા</th>
                                    </tr>
                                </thead>
                                <tbody id="students-list-body" class="divide-y divide-slate-100 text-sm"></tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- 3. ATTENDANCE TAB -->
                <div id="tab-attendance" class="tab-content hidden space-y-6">
                    <div class="bg-white/95 backdrop-blur-md p-6 rounded-3xl border border-slate-200 shadow-xl shadow-slate-100/40">
                        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-6">
                            <div>
                                <h3 class="font-black text-slate-900 text-xl">હાજરી પત્રક</h3>
                                <p class="text-xs font-semibold text-slate-400 mt-0.5">વિદ્યાર્થીઓની લાઈવ દૈનિક હાજરી પૂરો</p>
                            </div>
                            <div class="flex flex-wrap gap-2 w-full sm:w-auto">
                                <input type="date" id="attendance-date" onchange="loadAttendance()" class="px-4 py-2.5 border border-slate-200 rounded-2xl text-sm outline-none focus:ring-2 focus:ring-violet-400 transition bg-white font-bold text-slate-700">
                                <button onclick="markAllAttendance(true)" class="bg-emerald-500 hover:bg-emerald-600 text-white px-4 py-2.5 rounded-2xl text-xs font-extrabold shadow-md shadow-emerald-500/20 transition">બધા હાજર</button>
                                <button onclick="markAllAttendance(false)" class="bg-rose-500 hover:bg-rose-600 text-white px-4 py-2.5 rounded-2xl text-xs font-extrabold shadow-md shadow-rose-500/20 transition">બધા ગેરહાજર</button>
                            </div>
                        </div>

                        <div class="overflow-x-auto">
                            <table class="w-full text-left">
                                <thead>
                                    <tr class="border-b border-slate-100 text-xs text-slate-400 font-bold uppercase tracking-wider">
                                        <th class="pb-3 px-2">વિદ્યાર્થી નામ</th>
                                        <th class="pb-3 px-2 text-center">હાજરી સ્થિતિ (P/A)</th>
                                    </tr>
                                </thead>
                                <tbody id="attendance-list-body" class="divide-y divide-slate-100 text-sm"></tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- 4. FEES TAB -->
                <div id="tab-fees" class="tab-content hidden space-y-6">
                    <div class="bg-white/95 backdrop-blur-md p-6 rounded-3xl border border-slate-200 shadow-xl shadow-slate-100/40">
                        <h3 class="font-black text-slate-900 text-xl mb-4">ફી ટ્રેકર ડેસ્ક</h3>
